{
  "name": "db-context-enrichment-marketplace",
  "owner": {
    "name": "Google Cloud Platform",
    "url": "https://cloud.google.com/"
  },
  "plugins": [
    {
      "name": "db-context-engineering",
      "description": "Context Engineering Agent for generating natural language to SQL templates, facets, and value searches.",
      "source": {
        "source": "git-subdir",
        "url": "GoogleCloudPlatform/db-context-enrichment",
        "path": "plugin",
        "ref": "v0.5.1"
      },
      "homepage": "https://github.com/GoogleCloudPlatform/db-context-enrichment",
      "repository": "https://github.com/GoogleCloudPlatform/db-context-enrichment",
      "license": "Apache-2.0",
      "keywords": ["database", "sql", "nl2sql", "context-engineering", "mcp"],
      "category": "data",
      "strict": false,
      "mcpServers": {
        "db-context-engineering": {
          "command": "uvx",
          "args": [
            "google-cloud-db-context-engineering"
          ]
        },
        "toolbox": {
          "command": "npx",
          "args": [
            "-y",
            "@toolbox-sdk/server",
            "--config",
            "autoctx/tools.yaml",
            "--stdio"
          ]
        }
      }
    }
  ]
}
